# Single source of truth for the pinned Sparkle release (CS-064).
#
# Consumed by scripts/fetch-sparkle.sh (the framework the app embeds from
# Vendor/) and by .github/workflows/release.yml (the generate_appcast tooling
# that signs the update feed), so the runtime and the appcast can never drift
# apart. Bump both values together: the sha256 is of Sparkle-<version>.tar.xz
# from the official GitHub release; a mismatch fails the build rather than
# running an unverified binary.
SPARKLE_VERSION="2.9.3"
SPARKLE_TARBALL_SHA256="74a07da821f92b79310009954c0e15f350173374a3abe39095b4fc5096916be6"
