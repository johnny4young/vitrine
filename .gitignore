# ---------------------------------------------------------------------------
# Xcode
# ---------------------------------------------------------------------------
## User settings & state
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.xcscmblueprint
*.xccheckout

## Build products
build/
DerivedData/
# Packaged release artifacts (scripts/build-dmg.sh writes DMGs here).
dist/
# Session evidence from audit/validation runs (screenshots, reports) — local only.
.audit/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## Obj-C/Swift specific
*.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata

# ---------------------------------------------------------------------------
# Swift Package Manager
# ---------------------------------------------------------------------------
# Ignore the SPM build/cache dirs. Dependencies are exact-pinned in `project.yml`;
# the generated project's resolved state is not a repository input.
.build/
.swiftpm/
Packages/

# ---------------------------------------------------------------------------
# XcodeGen
# ---------------------------------------------------------------------------
# `project.yml` is the source of truth. The `.xcodeproj` is GENERATED from it
# (`xcodegen generate`) and is intentionally NOT tracked, so it never drifts
# from the spec. Run `xcodegen generate` (or `make project`) after cloning.
Vitrine.xcodeproj/

