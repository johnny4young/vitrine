docs/PLANNING.md
docs/ROADMAP.md
docs/ROADMAP-*.md
docs/ANALYSIS*.md
docs/PRE-LAUNCH*.md
docs/*BACKLOG*.md
docs/*TICKET*.md
docs/*FEATURE-IDEAS*.md
docs/*HANDOFF*.md
docs/*AUDIT*.md
docs/*REVIEW*.md
planning/
backlog/
tickets/

# ---------------------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------------------
# Shared project config (.claude/settings.json), the reviewer agents
# (.claude/agents/), and the release skill (.claude/skills/release/) ARE
# committed; machine-local overrides and per-session plugin installs are not.
.claude/settings.local.json
.claude/worktrees/
# Plugin skills are fetched into .claude/skills/ per session — ignore them all
# but keep the committed `release` skill tracked.
.claude/skills/*
!.claude/skills/release/
.agents/
.codex/
skills-lock.json
# ---------------------------------------------------------------------------
# Tooling / misc
# ---------------------------------------------------------------------------
*.log
.env
.env.local

# Coverage profiles
*.profraw
*.profdata
Vendor/

# Local working mirror of the Claude Design "Vitrine Design System" (design-sync pull)
docs/design/

