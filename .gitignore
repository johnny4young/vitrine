# ---------------------------------------------------------------------------
# Xcode
# ---------------------------------------------------------------------------
## User settings & state
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.xcscmblueprint
*.xccheckout

## Build products
build/
DerivedData/
# Packaged release artifacts (scripts/build-dmg.sh writes DMGs here; CS-061).
dist/
# Session evidence from audit/validation runs (screenshots, reports) — local only.
.audit/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## Obj-C/Swift specific
*.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata

# ---------------------------------------------------------------------------
# Swift Package Manager
# ---------------------------------------------------------------------------
# We commit Package.resolved (pinned versions) but ignore the build/cache dirs.
.build/
.swiftpm/
Packages/
# Resolved package state lives inside the generated .xcodeproj; it is ignored
# below together with the rest of the generated project.

# ---------------------------------------------------------------------------
# XcodeGen
# ---------------------------------------------------------------------------
# `project.yml` is the source of truth. The `.xcodeproj` is GENERATED from it
# (`xcodegen generate`) and is intentionally NOT tracked, so it never drifts
# from the spec. Run `xcodegen generate` (or `make project`) after cloning.
Vitrine.xcodeproj/

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon

# ---------------------------------------------------------------------------
# Working docs (kept local — detailed implementation spec, not tracked)
# ---------------------------------------------------------------------------
docs/ROADMAP.md
# Maintainer-only pre-launch runbook (credential setup + go-to-market notes).
docs/PRE-LAUNCH.md

# ---------------------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------------------
# Shared project config (.claude/settings.json), the reviewer agents
# (.claude/agents/), and the release skill (.claude/skills/release/) ARE
# committed; machine-local overrides and per-session plugin installs are not.
.claude/settings.local.json
# Plugin skills are fetched into .claude/skills/ per session — ignore them all
# but keep the committed `release` skill tracked.
.claude/skills/*
!.claude/skills/release/
.agents/
skills-lock.json
# ---------------------------------------------------------------------------
# Tooling / misc
# ---------------------------------------------------------------------------
*.log
.env
.env.local

# Coverage profiles
*.profraw
*.profdata
Vendor/

# Local working mirror of the Claude Design "Vitrine Design System" (design-sync pull)
docs/design/

# BSD `script` default capture file (dev artifact)
typescript
