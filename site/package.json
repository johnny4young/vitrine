{
  "name": "vitrine-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Static marketing site for Vitrine, built with Astro and vanilla web technologies.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node scripts/validate-build.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "test": "npm run check && npm run build",
    "deploy": "wrangler pages deploy dist --project-name=vitrine-web --branch=main"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3",
    "wrangler": "4.113.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "sharp": "0.35.3"
  }
}
