<!-- ============ INSTALL ============ -->
<section id="install" class="install" style="padding-top:0">
  <div class="wrap">
    <span class="eyebrow" data-i18n="inst.eyebrow">Install</span>
    <h2 class="title" data-i18n="inst.title">Two commands away.</h2>
    <p class="lead" data-i18n="inst.lead" style="margin-inline:auto">Install with Homebrew, or grab the signed, notarized DMG. Either way, the <code>vitrine</code> CLI lands on your PATH.</p>
    <div class="terminal">
      <span class="prompt">$</span>
      <code id="brew-cmd">brew install --cask johnny4young/tap/vitrine</code>
      <button id="copy-brew" aria-label="Copy install command"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="8.5" y="8.5" width="11" height="11" rx="2"></rect><path d="M5.5 15.5H5a1.5 1.5 0 0 1-1.5-1.5V5A1.5 1.5 0 0 1 5 3.5h9A1.5 1.5 0 0 1 15.5 5v.5"></path></svg> Copy</button>
    </div>
    <div class="cta" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:22px">
      <a class="btn btn-primary" data-download href="/download"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5v11M7.5 10l4.5 4.5L16.5 10M5 19.5h14"></path></svg><span data-i18n="inst.dmg">Download the DMG</span></a>
      <a class="btn btn-ghost" href="https://github.com/johnny4young/vitrine#getting-started"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 6l5 6-5 6M13 18h6"></path></svg><span data-i18n="inst.src">Build from source</span></a>
    </div>
  </div>
</section>
