<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<!-- Localization (CS-047): advertise English (development language) plus
	     Spanish so the app reports a real second locale and the system offers it
	     in Language & Region. The strings themselves live in the String Catalog
	     (Localizable.xcstrings). -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>es</string>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Vitrine</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.developer-tools</string>
	<!-- Register the bundled monospaced fonts at launch (Contents/Resources/Fonts). -->
	<key>ATSApplicationFontsPath</key>
	<string>Fonts</string>
	<!-- Menu-bar agent: no Dock icon, no app-switcher entry (CS-001). -->
	<key>LSUIElement</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 johnny4young. MIT-licensed.</string>
	<!-- The app reads the clipboard locally to render code/URLs; nothing leaves the
	     Mac (CS-045). Phase 1 promise is unchanged: copied code is turned into an
	     image entirely on-device. In Product Phase 2, a copied URL is captured by
	     loading the requested webpage locally in WebKit on this Mac — there is no
	     remote screenshot service, no account, and no analytics or telemetry.
	     This is the only declared usage string; it is the Info.plist row of the
	     permission matrix in docs/PERMISSIONS.md (CS-065). No Screen Recording usage
	     string is declared — arbitrary screen capture stays parked until approved
	     (CS-046). Tests/PrivacyManifestTests.swift fails on drift. -->
	<key>NSPasteboardUsageDescription</key>
	<string>Vitrine reads the clipboard to turn copied code or a URL into an image. Code never leaves your Mac, and a URL is captured by loading the webpage locally in WebKit on your Mac.</string>
	<!-- Services menu action (CS-034): "Render Code Image with Vitrine" takes a
	     text selection from any app and returns a rendered PNG image. The runtime
	     provider is registered in AppDelegate (NSApp.servicesProvider); this
	     declaration is what populates the system-wide Services menu. Rendering is
	     fully local — the selection is turned into an image on-device. -->
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Render Code Image with Vitrine</string>
			</dict>
			<key>NSMessage</key>
			<string>renderCodeImage</string>
			<key>NSPortName</key>
			<string>Vitrine</string>
			<!-- Accept a plain-text selection. -->
			<key>NSSendTypes</key>
			<array>
				<string>public.utf8-plain-text</string>
				<string>public.plain-text</string>
				<string>NSStringPboardType</string>
			</array>
			<!-- Return a rendered image so the host app can paste or drop it. -->
			<key>NSReturnTypes</key>
			<array>
				<string>public.png</string>
				<string>public.tiff</string>
			</array>
			<!-- A short, stable identifier for this service. -->
			<key>NSUserData</key>
			<string>com.johnny4young.vitrine.render-code-image</string>
		</dict>
	</array>
	<!-- Sparkle auto-update channel (CS-064, see docs/RELEASING.md). These keys
	     configure the direct-download update story; the App Store build excludes
	     Sparkle entirely (it removes the VITRINE_DIRECT_DOWNLOAD compilation
	     condition and strips the framework — see docs/APP-STORE.md), so Sparkle
	     ignores these keys there. -->
	<!-- The appcast feed: a signed RSS feed Sparkle polls to learn about new
	     versions. It is served over HTTPS from the GitHub Pages site for this
	     repository and is republished on every GitHub release (see
	     .github/workflows/release.yml). Sparkle compares the feed's entries to this
	     bundle's CFBundleVersion to decide whether an update is available. -->
	<key>SUFeedURL</key>
	<string>https://johnny4young.github.io/vitrine/appcast.xml</string>
	<!-- The EdDSA (ed25519) public key Sparkle uses to verify every downloaded
	     update's signature before installing it. The matching PRIVATE key never
	     leaves the release maintainer's Keychain; the appcast's signatures are
	     produced by Sparkle's `sign_update` at release time. A build whose download
	     does not verify against this key is rejected, which is what makes a
	     direct-download update safe against tampering and man-in-the-middle attacks.
	     The key pair was generated with Sparkle's `generate_keys` (docs/RELEASING.md);
	     the public half is below; the private half is the SPARKLE_EDDSA_PRIVATE_KEY secret. -->
	<key>SUPublicEDKey</key>
	<string>Y5DOypMB7sZ04Ffw2gkLr9BlZRHKGWgWu0bB9jEsqmU=</string>
	<!-- Privacy: Sparkle's optional anonymous system-profiling feature is OFF, so an
	     update check sends no usage data — only the request needed to fetch the
	     appcast and the chosen download. This keeps the app's no-analytics, no-
	     telemetry promise on the update path too (CS-064; mirrors the privacy posture
	     documented in docs/PERMISSIONS.md and PrivacyInfo.xcprivacy). No profiling
	     delegate is installed in code either, so this cannot be silently re-enabled. -->
	<key>SUEnableSystemProfiling</key>
	<false/>
</dict>
</plist>
