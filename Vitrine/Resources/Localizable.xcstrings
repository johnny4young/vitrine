      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press the global hotkey from any app to capture whatever code is on your clipboard as an image. Set or change the hotkey below, or in Settings ▸ General."
