    "help.topic.presets.body" : {
      "comment" : "Help topic body: presets.",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destination presets size the image for where it is going (a README, a social card, a slide). Style presets save a look you like so you can reapply it in one click. Manage both in Settings ▸ Style."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los ajustes preestablecidos de destino dimensionan la imagen para su lugar de publicación (un README, una tarjeta social, una diapositiva). Los de estilo guardan un aspecto que te gusta para reaplicarlo con un clic. Administra ambos en Ajustes ▸ Estilo."
          }
        }
      }
    },
