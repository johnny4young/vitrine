    "help.topic.editor.body" : {
      "comment" : "Help topic body: the editor.",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open the editor to paste or type code, pick a language and theme, and fine-tune padding, corner radius, window chrome, and line numbers. Copy, save, or share the result from the toolbar or the File menu."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre el editor para pegar o escribir código, elegir un lenguaje y un tema, y ajustar el relleno, el radio de las esquinas, el marco de ventana y los números de línea. Copia, guarda o comparte el resultado desde la barra de herramientas o el menú Archivo."
          }
        }
      }
    },
