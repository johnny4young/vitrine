    "help.topic.editor.body" : {
      "comment" : "Help topic body: the editor.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open the editor to paste or type code, pick a language and theme, and fine-tune padding, corner radius, window chrome, and line numbers. Copy, save, or share the result from the toolbar or the File menu."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre el editor para pegar o escribir código, elegir un lenguaje y un tema, y ajustar el relleno, el radio de las esquinas, el marco de ventana y los números de línea. Copia, guarda o comparte el resultado desde la barra de herramientas o el menú Archivo."
          }
        }
      }
    },
    "help.topic.editor.title" : {
      "comment" : "Help topic title: the editor.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The editor"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El editor"
          }
        }
      }
    },
    "help.topic.hotkey.body" : {
      "comment" : "Help topic body: the global hotkey.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Press the global hotkey from any app to capture whatever code is on your clipboard as an image. Set or change the hotkey below, or in Settings ▸ General."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Presiona el atajo global desde cualquier app para capturar como imagen el código que tengas en el portapapeles. Configura o cambia el atajo abajo, o en Ajustes ▸ General."
          }
        }
      }
    },
    "help.topic.hotkey.title" : {
      "comment" : "Help topic title: the global hotkey.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The global hotkey"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El atajo global"
          }
        }
      }
    },
    "help.topic.presets.body" : {
      "comment" : "Help topic body: presets.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Destination presets size the image for where it is going (a README, a social card, a slide). Style presets save a look you like so you can reapply it in one click. Manage both in Settings ▸ Style."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los ajustes preestablecidos de destino dimensionan la imagen para su lugar de publicación (un README, una tarjeta social, una diapositiva). Los de estilo guardan un aspecto que te gusta para reaplicarlo con un clic. Administra ambos en Ajustes ▸ Estilo."
          }
        }
      }
    },
    "help.topic.presets.title" : {
      "comment" : "Help topic title: presets.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Presets"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajustes preestablecidos"
          }
        }
      }
    },
    "help.topic.privacy.body" : {
      "comment" : "Help topic body: privacy.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vitrine is private by design: your code never leaves your Mac. There is no account and no network access, and rendering needs no screen-recording or Accessibility permission."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vitrine es privado por diseño: tu código nunca sale de tu Mac. No hay cuenta ni acceso a la red, y la generación no necesita permiso de grabación de pantalla ni de Accesibilidad."
          }
        }
      }
    },
    "help.topic.privacy.title" : {
      "comment" : "Help topic title: privacy.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacidad"
          }
        }
      }
    },
    "help.topic.quick-capture.body" : {
      "comment" : "Help topic body: quick capture.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Copy code anywhere, press the hotkey, and Vitrine renders it with your current style. The image is placed on your clipboard automatically — paste it straight into a doc, chat, or pull request."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Copia código en cualquier parte, presiona el atajo y Vitrine lo genera con tu estilo actual. La imagen se coloca en el portapapeles automáticamente; pégala directamente en un documento, chat o pull request."
          }
        }
      }
    },
    "help.topic.quick-capture.title" : {
