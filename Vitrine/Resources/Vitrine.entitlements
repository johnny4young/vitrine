<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox on. Deliberately NO com.apple.security.network.client:
	     the core is fully local (CS-011), and Product Phase 2 URL capture (CS-043)
	     stays disabled until this entitlement is deliberately added. The renderer
	     reads this entitlement at runtime (NetworkCapability) and refuses a URL
	     capture while it is absent, so a Phase 1 build provably cannot reach the
	     network. Adding the key here is the single switch that enables URL capture;
	     CS-045/CS-062 also update the privacy copy and App Store posture when it is. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- User-selected file access only. This single entitlement covers every
	     file the app touches: saving rendered images via NSSavePanel (CS-007),
	     importing presets/themes/backgrounds via NSOpenPanel (CS-030/031/051),
	     and loading a source file the user drags onto the editor (CS-028). A
	     dropped file's URL is a user-selected, security-scoped resource, so drop
	     input needs NO additional or broader file entitlement. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
